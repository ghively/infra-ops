{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/infra-session-bootstrap.js\""
          }
        ],
        "description": "Prime the session with SPEC/TODO/knowledge pointers and the hard trust-boundary rules",
        "id": "infra:session:bootstrap"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/sensitivity-router.js\"",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/gateguard-fact-force.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pan-egress-filter.js\""
          }
        ],
        "description": "CHD routing to local lane; GateGuard investigation gate; DLP PAN/secrets blocking",
        "id": "infra:pre:sensitivity-gateguard-pan-filter"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/governance-capture.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/observe-runner.js\"",
            "async": true,
            "timeout": 3
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/governance-ledger.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Governance capture, observation, and audit ledger (PCI Req 10)",
        "id": "infra:post:governance-observe-ledger"
      }
    ]
  }
}
