{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/infra-session-bootstrap.js\""
          }
        ],
        "description": "Prime the session with SPEC/TODO/knowledge pointers and the hard trust-boundary rules",
        "id": "infra:session:bootstrap"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pan-egress-filter.js\""
          }
        ],
        "description": "DLP: block any tool call whose input contains a Luhn-valid PAN or a high-confidence secret",
        "id": "infra:pre:pan-egress-filter"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/governance-ledger.js\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Append a fingerprinted, append-only audit record per tool use (PCI Req 10 / CP §6.4 feed)",
        "id": "infra:post:governance-ledger"
      }
    ]
  }
}
