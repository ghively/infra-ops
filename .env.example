# infra-ops plugin — environment variables reference
# Copy relevant variables to your shell profile or CI/CD variables.
# Variables commented out with '#' are optional or disabled by default.
#
# Namespace: all infra-ops variables use the INFRAOPS_* prefix.
# Legacy INFRA_OPS_* names are still accepted as back-compat aliases.

# ─── Security defaults (fail-closed by design) ─────────────────────────────
# Both DLP and sensitivity routing default to FAIL-CLOSED on a fresh install.
# The agent will deny any tool calls it cannot inspect or that appear CHD-adjacent
# until you explicitly loosen these defaults.

# PAN/secret DLP gate (pan-egress-filter hook).
# Default: fail-closed (deny on parse error or internal error).
# Set to 0 to make the gate fail-open (not recommended for CDEs).
# INFRAOPS_DLP_FAIL_CLOSED=0

# CHD-adjacent sensitivity router (sensitivity-router hook).
# Default: fail-closed (deny CHD-adjacent tool calls).
# Set to 0 to switch to advisory mode (logs warning, does not deny).
# INFRAOPS_SENSITIVE_FAIL_CLOSED=0

# ─── Local inference lane ───────────────────────────────────────────────────
# Required to enable the local lane for CHD-adjacent work.
# The sensitive-local-analyst agent routes inference here.
# OLLAMA_BASE_URL=http://localhost:11434

# Require Ollama endpoint to be localhost/RFC1918. Default: 1 (enforced).
# INFRAOPS_OLLAMA_REQUIRE_LOCAL=1

# ─── Sensitivity routing ────────────────────────────────────────────────────
# Global disable switch for the sensitivity router (not recommended).
# Set to 0 to disable the router entirely (all CHD-adjacent calls allowed).
# INFRAOPS_SENSITIVITY_ROUTE=0

# ─── Governance and audit ───────────────────────────────────────────────────
# SIEM endpoint for forwarding governance events (governance-ledger hook).
# Leave unset to store events in the State Store only (no forwarding).
# INFRAOPS_AUDIT_FORWARD=https://your-siem.example.com/ingest

# State store root directory. Default: ~/.infra-ops/state-store/
# INFRAOPS_STATE_DIR=/custom/path/to/state-store

# Session identifier for correlating governance events and observations.
# Auto-detected from CLAUDE_SESSION_ID if set by the harness.
# INFRAOPS_SESSION_ID=

# Enable governance event capture (governance-capture hook).
# INFRAOPS_GOVERNANCE_CAPTURE=1

# Enable tool usage observation (observe-runner hook).
# INFRAOPS_OBSERVE=1

# ─── Quality hooks ──────────────────────────────────────────────────────────
# These are set automatically by hooks/hooks.json on Edit/Write tool calls.
# Listed here for documentation. Override manually if needed.
# INFRAOPS_YAMLLINT=1           (set by PostToolUse hook — runs yamllint on .yml/.yaml files)
# INFRAOPS_ANSIBLE_SYNTAX=1    (set by PostToolUse hook — runs ansible --syntax-check on playbooks)
