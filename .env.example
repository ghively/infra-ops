# infra-ops Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# Local Model Configuration (for CHD-adjacent work)
# ============================================================================
# Ollama endpoint for local-only model lane
# Used when routing sensitive work that must not leave the premises
OLLAMA_BASE_URL=http://localhost:11434

# Default local model for the lane (a tool-calling-capable model is recommended)
INFRAOPS_OLLAMA_MODEL=qwen2.5-coder:32b

# Refuse non-local OLLAMA_BASE_URL so the lane cannot egress. "1" (default) = enforce.
# Set to "0" ONLY if OLLAMA_BASE_URL is a verified in-zone box on a private network.
INFRAOPS_OLLAMA_REQUIRE_LOCAL=1

# Local inference request timeout in milliseconds
INFRAOPS_OLLAMA_TIMEOUT_MS=120000

# Sensitivity router: detects CHD-adjacent tool calls and routes to the local lane.
# Active by default (advisory). Set to "0" to disable entirely.
INFRAOPS_SENSITIVITY_ROUTE=1

# Make the sensitivity router fail-CLOSED: DENY CHD-adjacent tool calls instead of
# advising. Recommended for hardened / in-zone operation. Default: false.
INFRAOPS_SENSITIVE_FAIL_CLOSED=false

# ============================================================================
# Audit & Compliance
# ============================================================================
# SIEM endpoint for forwarding governance-ledger events in real time.
# Format: https://your-siem.example.com/api/logs
# (For Splunk HEC / Elastic, use the SIEM_TYPE / SIEM_ENDPOINT / SIEM_TOKEN vars.)
INFRAOPS_AUDIT_FORWARD=

# Governance capture: detect secrets/policy violations and persist to the State
# Store. Enabled in hooks.json by default; set to "0" to disable.
INFRAOPS_GOVERNANCE_CAPTURE=1

# Observation capture: record tool-usage patterns to the State Store (the input
# to the learning loop). Enabled in hooks.json by default; set to "0" to disable.
INFRAOPS_OBSERVE=1

# ============================================================================
# Security & DLP
# ============================================================================
# Make PAN/secret egress filter fail-closed (deny on error)
# Set to "true" for sensitive environments
INFRAOPS_DLP_FAIL_CLOSED=false

# ============================================================================
# Optional MCP servers (see docs/mcp-servers.md) — operator-supplied, READ-ONLY
# ============================================================================
# context7 + sequential-thinking are bundled. The servers below are NOT bundled;
# enable them in your MCP config only with read-only, least-privilege tokens.
#
# GitLab MCP (read-only): PAT with read_api scope only; the server runs with
# GITLAB_READ_ONLY_MODE=true so it can never merge/trigger/promote.
GITLAB_READ_TOKEN=
# Octopus MCP (read-only): API key for an account scoped to read; server runs --read-only.
OCTOPUS_READ_API_KEY=

# ============================================================================
# GitLab Configuration
# ============================================================================
# GitLab instance URL (for API access)
GITLAB_URL=https://gitlab.example.com

# GitLab personal access token (read + MR write only, no protected branch)
# Generate at: User Settings > Access Tokens
# Scopes: api, read_api, read_repository, write_repository
GITLAB_TOKEN=

# ============================================================================
# Ansible Configuration
# ============================================================================
# Ansible inventory path (default: playbook directory)
ANSIBLE_INVENTORY_PATH=

# ============================================================================
# Octopus Deploy Configuration
# ============================================================================
# Octopus server URL
OCTOPUS_URL=https://octopus.example.com

# Octopus API key
OCTOPUS_API_KEY=

# ============================================================================
# Development
# ============================================================================
# Enable verbose logging
ENABLE_VERBOSE_LOGGING=false

# Default base branch for operations
DEFAULT_BASE_BRANCH=main
